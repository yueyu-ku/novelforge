registry=https://registry.npmmirror.com
# 注意：electron_mirror 和 electron_builder_binaries_mirror 不再设置
# npmmirror 镜像缺少 dmg-builder@1.2.0 等新版二进制，会导致 404
# electron-builder 会自动从 GitHub releases 下载
electron_mirror=https://npmmirror.com/mirrors/electron/

# 自动处理依赖相关配置 (pnpm & electron-builder 打包)
shamefully-hoist=true
auto-install-peers=true
strict-peer-dependencies=false

# 允许所有依赖运行构建脚本（解决 electron-winstaller 等报错）
onlyBuiltDependencies=*
